# ── MMSkillTrainer (mm_train.py) ───────────────────────────────────────────
BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=PASTE-YOURS

# ── Skill Evaluation Pipeline ─────────────────────────────────────────────
# Required for automatic skill evaluation when creating skills.
OPENAI_API_KEY=sk-PASTE-YOUR-OPENAI-KEY-HERE

# Model Agent used
MODEL=openai/gpt-5.4-nano

# Override the embedding model if your key doesn't have access to the default.
# Default: openai/text-embedding-3-small
# EVAL_EMBEDDING_MODEL=openai/text-embedding-ada-002

# Similarity threshold for matching skills to tasks (0-1). Default: 0.357
# EVAL_THRESHOLD=0.357

# Harbor config template for evaluation runs.
# EVAL_BASE_CONFIG=experiments/configs/sanity-check.yaml

# Agent and model used during Harbor evaluation runs.
# EVAL_AGENT_NAME=codex
# EVAL_MODEL_NAME=openai/gpt-5.2-codex