import os
from pathlib import Path

import dotenv

dotenv.load_dotenv(Path(__file__).with_name(".env"))

# Copy to config.py. Optional Reflexion defaults via .env (see reflexion_agent/agent.py):
#   ENABLE_REFLEXION=true|false — used when running the agent CLI without an explicit flag.
#   MAX_REFLEXION_ATTEMPTS=3
#   REFLEXION_SCORE_THRESHOLD=0.75 — numeric score at or above which the loop exits early,
#       even if the judge's binary success flag is False. Range: 0.0–1.0. Default: 0.75.
#       Set to 1.0 to disable the score escape hatch (only success=True can stop the loop).
#   REFLEXION_MEMORY_PATH= — override the default cross-session memory file location.
#       When blank or unset, uses the package default: reflexion_agent/data/reflexion_memory.json.
# The web UI sends use_reflexion on each POST /api/chat request (default false); that
# overrides the env default for that run.

BASE_URL = os.getenv("OPENAI_BASE_URL", "https://api.openai.com/v1")
API_KEY = os.getenv("OPENAI_API_KEY", "PASTE-YOUR-OPENAI-KEY-HERE")
AGENT_MODEL = "gpt-5.4"
VERIFIER_MODEL = "gpt-5.4"

OPENROUTER_BASE_URL = os.getenv("OPENROUTER_BASE_URL", "https://openrouter.ai/api/v1")
OPENROUTER_API_KEY = os.getenv("OPENROUTER_API_KEY", "PASTE-YOUR-OPENROUTER-KEY-HERE")
OPENROUTER_SKILL_MODEL = os.getenv("OPENROUTER_SKILL_MODEL", "google/gemini-2.5-flash")

# PostgreSQL — used by the skill marketplace.
# Local dev default: postgresql+asyncpg://postgres:postgres@localhost:5432/skillmarket
DATABASE_URL = "postgresql+asyncpg://postgres:postgres@localhost:5432/skillmarket"
