"""Runtime configuration — copy this file to ``config.py`` and edit if needed.

    cp backend/config.py.example backend/config.py

The shipped values all come from environment variables (loaded from the
repo-root ``.env`` first, then ``backend/.env`` as an override), with
sensible defaults baked in. See ``.env.template`` at the repo root for
the full list of variables and what each one does.

Optional Reflexion defaults via ``.env`` (see ``reflexion_agent/agent.py``):
  ENABLE_REFLEXION=true|false       — default when the agent runs without an
                                       explicit flag. The web UI sends
                                       ``use_reflexion`` per request and that
                                       overrides this.
  MAX_REFLEXION_ATTEMPTS=3
  REFLEXION_SCORE_THRESHOLD=0.75    — judge-score at/above which the loop
                                       exits early even when ``success=False``.
                                       Range 0.0–1.0. Set to 1.0 to disable.
  REFLEXION_MEMORY_PATH=             — override the default cross-session
                                       memory file location.

Auto Test Generation settings (see ``test_case_generator.py`` and
``test_case_verifier.py``):

  Before first run, re-copy ``config.py`` from this example and set
  ``OPENAI_API_KEY`` in ``.env`` (must be a valid OpenAI key, not OpenRouter).
  Set ``VERIFIER_MODEL`` to an ``openai/...`` model (e.g. ``openai/gpt-4o-mini``).
  Non-OpenAI model strings raise ``RuntimeError`` at generation/verification time.

  OPENAI_API_KEY=                    — required; used by the test-case generator
                                       and the LLM judge (OpenAI client only).
  VERIFIER_MODEL=                    — must be ``openai/...`` for auto-tests.
  TEST_CASE_DEFAULT_MAX_LATENCY_MS=  — fallback latency cap (ms) when the LLM
                                       does not supply one (default: 120000).
  TEST_CASE_MIN_LATENCY_MS=          — hard floor applied to every test run so
                                       no case can time out before the agent
                                       even starts (default: 120000).
"""

from __future__ import annotations

import os
from pathlib import Path

import dotenv

_BACKEND_DIR = Path(__file__).resolve().parent
_REPO_ROOT = _BACKEND_DIR.parent

# Repo-root ``.env`` is the canonical location; ``backend/.env`` is a
# per-backend override that wins when both are present.
dotenv.load_dotenv(_REPO_ROOT / ".env")
dotenv.load_dotenv(_BACKEND_DIR / ".env", override=True)

# ── OpenRouter (chat agent, trajectory annotation) ──────────────────────────
BASE_URL = os.getenv("OPENROUTER_BASE_URL", "https://api.openai.com/v1")
API_KEY = os.getenv("OPENAI_API_KEY")

# ── Model ids ───────────────────────────────────────────────────────────────
AGENT_MODEL = os.getenv("AGENT_MODEL", "openai/gpt-5.4")
SKILL_MODEL = os.getenv("SKILL_MODEL", "google/gemini-2.5-flash")
VERIFIER_MODEL = os.getenv("VERIFIER_MODEL", "openai/gpt-5.4-nano-2026-03-17")
SKILL_SELECTION_MODEL = os.getenv("SKILL_SELECTION_MODEL", "openai/gpt-4o")

# ── Auto Test Generation ─────────────────────────────────────────────────────
# Requires an OpenAI API key — the generator and verifier use the OpenAI client.
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY", "")
# Latency cap applied when the LLM omits max_latency_ms.
TEST_CASE_DEFAULT_MAX_LATENCY_MS = int(os.getenv("TEST_CASE_DEFAULT_MAX_LATENCY_MS", "240000"))
# Hard floor — no test run can time out before the agent has had at least this
# many milliseconds to respond, regardless of what the generated case says.
TEST_CASE_MIN_LATENCY_MS = int(os.getenv("TEST_CASE_MIN_LATENCY_MS", "120000"))

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Leave empty to use the in-memory fallback. Set this in ``.env`` when you
# want persistent Postgres-backed skills/employees.
DATABASE_URL = os.getenv("DATABASE_URL", "")
