# =============================================================================
# Environment variables — copy this file to `.env` at the repo root and fill
# in the keys you need. `.env` is gitignored; never commit real keys.
#
#     cp .env.template .env
#
# The backend auto-loads `.env` on startup via python-dotenv. See
# `backend/config.py` for how each variable is consumed and the defaults that
# apply when a variable is unset.
# =============================================================================

# OpenAI direct API. Used by the employee-creation wizard to expand a short
# description into a full system prompt (gpt-4o / gpt-4o-mini / etc.). Leave
# blank if you only run the chat agent and don't use the wizard's expansion.
OPENAI_API_KEY=

# OpenRouter. Used by the chat agent and the trajectory-annotation pass.
# Leave blank to run in mock / no-LLM mode.
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Optional overrides — backend/config.py already has sensible defaults.
# Uncomment a line below only if you need to deviate from the default.
# -----------------------------------------------------------------------------

# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AGENT_MODEL=openrouter/minimax/minimax-m2.7
# SKILL_MODEL=google/gemini-2.5-flash
# VERIFIER_MODEL=openai/gpt-4o
# SKILL_SELECTION_MODEL=openai/gpt-4o
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skillmarket

# -----------------------------------------------------------------------------
# Reflexion agent — read directly by backend/reflexion_agent/agent.py, not by
# config.py. The web UI sends ``use_reflexion`` per chat request and that
# overrides these; these act as defaults for CLI / non-web invocations.
# -----------------------------------------------------------------------------

# ENABLE_REFLEXION=false
# MAX_REFLEXION_ATTEMPTS=3
# REFLEXION_SCORE_THRESHOLD=0.75
# REFLEXION_MEMORY_PATH=
